# URL pública para Socket.io (tunnel o dominio de producción)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Link del botón Sponsor en la topbar
NEXT_PUBLIC_SPONSOR_URL=https://ko-fi.com/lucasmella

# Puerto del servidor
PORT=3000

# (Opcional) Token de ngrok para el tunnel de desarrollo — pnpm tunnel
# Obtener en: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
